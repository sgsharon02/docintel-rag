# =====================================================
# DocIntel Environment Configuration
# Copy this file to .env and fill in required values.
# =====================================================

# -------------------------
# Provider Selection
# -------------------------
LLM_PROVIDER=llama
EMBEDDING_PROVIDER=local

# Options:
# LLM_PROVIDER = ibm | gcp | llama | mock
# EMBEDDING_PROVIDER = ibm | gcp | local | mock

# -------------------------
# Local Models
# -------------------------
LOCAL_LLM_MODEL=llama3
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# -------------------------
# IBM watsonx Configuration
# -------------------------
WATSONX_API_KEY=
IBM_PROJECT_ID=
IBM_MODEL_ID=ibm/granite-3-3-8b-instruct
IBM_EMBEDDING_MODEL=ibm/slate-30m-english-rtrvr
IBM_URL=https://us-south.ml.cloud.ibm.com

# -------------------------
# Google Vertex AI Configuration
# -------------------------
GCP_PROJECT_ID=
GCP_LOCATION=us-central1
GCP_MODEL_ID=gemini-1.5-pro
GCP_EMBEDDING_MODEL=textembedding-gecko@003
